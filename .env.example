# InsightOS local environment

COMPOSE_PROJECT_NAME=insightos

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
APP_NAME=InsightOS API
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_USER=insightos
POSTGRES_PASSWORD=insightos
POSTGRES_DB=insightos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://insightos:insightos@postgres:5432/insightos

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
