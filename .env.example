# InsightOS local environment

COMPOSE_PROJECT_NAME=insightos

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Backend
APP_NAME=InsightOS API
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# Trusted data connectors
# SEC requires an identifiable User-Agent. Replace the email before live requests.
SEC_USER_AGENT=InsightOS/0.1 contact=your-email@example.com
# FRED live requests require an API key. Leave empty to keep FRED disabled locally.
FRED_API_KEY=
CONNECTOR_TIMEOUT_SECONDS=10
CONNECTOR_CACHE_TTL_SECONDS=300

# PostgreSQL
POSTGRES_USER=insightos
POSTGRES_PASSWORD=insightos
POSTGRES_DB=insightos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://insightos:insightos@postgres:5432/insightos

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
